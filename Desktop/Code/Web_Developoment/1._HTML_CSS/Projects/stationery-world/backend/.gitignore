node_modules/.prisma/

# ─── Uploaded files (served at runtime, not stored in git) ───────────────────
uploads/
!uploads/.gitkeep

# ─── Archives / backups ──────────────────────────────────────────────────────
*.zip
*.tar.gz
*.tar
*.gz

# ─── OS junk ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
