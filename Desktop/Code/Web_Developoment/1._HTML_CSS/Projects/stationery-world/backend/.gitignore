# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Environment & secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env

# ─── Build / generated ───────────────────────────────────────────────────────
dist/
build/

# ─── Prisma generated client (re-created by `prisma generate`) ───────────────
