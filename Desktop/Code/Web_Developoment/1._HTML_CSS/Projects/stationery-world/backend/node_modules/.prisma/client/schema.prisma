// =====================================================
// STATIONERY WORLD — COMPLETE PRISMA SCHEMA
// Version: 2.1.0
// Changes from previous:
//   - Order: added paidAt, refundedAt, refundAmount, refundIssued, paymentMethod
//   - OrderStatus: removed duplicate CANCELED (kept CANCELLED only)
//   - User: cleaned up relation names
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// USERS & AUTHENTICATION
// =====================================================

model User {
  id    Int     @id @default(autoincrement())
  name  String
  email String  @unique
  phone String? @unique

  // Profile & Address Fields
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?
  photoUrl     String?

  passwordHash String
  role         Role    @default(CUSTOMER)
  isActive     Boolean @default(true)

  // Relations
  orders               Order[]               @relation("UserOrders")
  adminOrders          Order[]               @relation("AdminOrders")
  placedOrders         Order[]               @relation("PlacedByOrders")
  wishlists            Wishlist[]
  payments             Payment[]
  bargainAttempts      BargainAttempt[]
  cartItems            Cart[]
  inventoryLogs        InventoryLog[]
  orderAudits          OrderAudit[]
  profitLedger         ProfitLedger[]
  otps                 OTP[]
  createdProducts      Product[]             @relation("ProductCreatedBy")
  productNotifications ProductNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

enum Role {
  CUSTOMER
  ADMIN
}

// =====================================================
// OTP FOR PASSWORD RESET
// =====================================================

model OTP {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  email     String
  otp       String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([otp])
  @@index([userId])
  @@map("otp")
}

// =====================================================
// PRODUCTS & CATALOG
// =====================================================

model Product {
  id          Int      @id @default(autoincrement())
  uid         String?  @unique @default(uuid())
  name        String
  description String?
  keywords    String[] @default([])
  category    Category
  subCategory String

  // Pricing
  costPrice        Float
  baseSellingPrice Float
  bargainable      Boolean @default(true)

  // Stock Management
  totalStock        Int     @default(0)
  totalSold         Int     @default(0)
  lowStockThreshold Int     @default(10)
  isActive          Boolean @default(true)

  // Creator tracking
  createdBy   User? @relation("ProductCreatedBy", fields: [createdById], references: [id])
  createdById Int?

  // Relations
  images          ProductImage[]
  inventoryLogs   InventoryLog[]
  bargainConfig   BargainConfig?
  orderItems      OrderItem[]
  wishlists       Wishlist[]
  bargainAttempts BargainAttempt[]
  cartItems       Cart[]
  notifications   ProductNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([uid])
  @@index([category])
  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  url       String
  altText   String?
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("product_images")
}

model InventoryLog {
  id        Int             @id @default(autoincrement())
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  action    InventoryAction
  quantity  Int
  admin     User?           @relation(fields: [adminId], references: [id])
  adminId   Int?
  note      String?
  createdAt DateTime        @default(now())

  @@index([productId])
  @@map("inventory_logs")
}

enum InventoryAction {
  ADD
  RESTOCK
  SALE
  ADJUST
  ORDER_DEDUCTION
  ORDER_RESTORATION
}

enum Category {
  STATIONERY
  BOOKS
  TOYS
}

// =====================================================
// BARGAINING SYSTEM
// =====================================================

model BargainConfig {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int     @unique

  // Existing fields
  tier1Price  Float
  tier2Price  Float
  tier3Price  Float
  maxAttempts Int     @default(3)
  isActive    Boolean @default(true)

  // ✨ ADD THESE NEW FIELDS:
  bargainPercentageLimit        Float?
  bargainAmountLimit            Float?
  minimumCartValueForBargain    Float?
  minimumCustomerOrdersRequired Int?      @default(0)
  bargainExpiryDate             DateTime?
  bargainStockLimit             Int?
  bargainStockUsed              Int       @default(0)
  cooldownMinutes               Int       @default(30)
  lockDurationMinutes           Int       @default(30)
  requiresLogin                 Boolean   @default(true)
  allowCouponCombination        Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, isActive])
  @@index([bargainExpiryDate])
  @@map("bargain_configs")
}

model BargainAttempt {
  id        Int     @id @default(autoincrement())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  order     Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)
  orderId   Int?

  // Existing fields
  attemptNumber Int
  offeredPrice  Float
  accepted      Boolean @default(false)

  // ✨ ADD THESE NEW FIELDS:
  acceptedTier    Int?
  finalPrice      Float?
  offerLockExpiry DateTime?
  rejectionReason String?
  isAbused        Boolean   @default(false)
  ipAddress       String?
  userAgent       String?
  addedToCart     Boolean   @default(false)
  cartAddedAt     DateTime?
  purchasedAt     DateTime?

  createdAt     DateTime @default(now())
  lastAttemptAt DateTime @default(now())

  @@unique([userId, productId, orderId])
  @@index([userId, productId])
  @@index([userId, isAbused])
  @@index([productId, accepted])
  @@index([offerLockExpiry])
  @@map("bargain_attempts")
}

// =====================================================
// CART SYSTEM
// =====================================================

model Cart {
  id        Int     @id @default(autoincrement())
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  quantity  Int     @default(1)

  priceAtAdd     Float
  bargainApplied Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@map("cart")
}

// =====================================================
// WISHLIST
// =====================================================

model Wishlist {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  addedAt   DateTime @default(now())
  note      String?

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist")
}

// =====================================================
// ORDERS & TRANSACTIONS
// =====================================================

model Order {
  id  Int    @id @default(autoincrement())
  uid String @unique @default(uuid())

  // User relationships
  user       User? @relation("UserOrders", fields: [userId], references: [id])
  userId     Int?
  placedBy   User? @relation("PlacedByOrders", fields: [placedById], references: [id])
  placedById Int?
  admin      User? @relation("AdminOrders", fields: [adminId], references: [id])
  adminId    Int?

  type   OrderType   @default(CUSTOMER)
  status OrderStatus @default(PENDING)

  // Payment tracking
  isPaid        Boolean        @default(false)
  paidAt        DateTime?
  paymentMethod PaymentMethod?

  // Refund tracking
  refundIssued Boolean   @default(false)
  refundedAt   DateTime?
  refundAmount Float?

  // Recipient & Delivery Information
  recipientName  String
  recipientPhone String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  country        String?
  note           String?

  // Financial Information
  totalAmount Float @default(0)
  totalSp     Float @default(0)
  totalCp     Float @default(0)

  // Relations
  items           OrderItem[]
  payment         Payment?
  bargainAttempts BargainAttempt[]
  audits          OrderAudit[]
  profitLedgers   ProfitLedger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([adminId])
  @@index([placedById])
  @@index([status])
  @@index([isPaid])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id      Int   @id @default(autoincrement())
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int

  product   Product? @relation(fields: [productId], references: [id])
  productId Int?

  // Product snapshot (immutable after creation)
  productName  String
  productPhoto String?

  quantity Int

  // Pricing snapshot
  cp             Float
  sp             Float
  subtotalSp     Float
  subtotalCp     Float
  priceAtOrder   Float
  bargainApplied Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@map("order_items")
}

model OrderAudit {
  id         Int         @id @default(autoincrement())
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId    Int
  admin      User?       @relation(fields: [adminId], references: [id])
  adminId    Int?
  fromStatus OrderStatus
  toStatus   OrderStatus
  note       String?
  createdAt  DateTime    @default(now())

  @@index([orderId])
  @@map("order_audits")
}

model ProfitLedger {
  id      Int     @id @default(autoincrement())
  admin   User    @relation(fields: [adminId], references: [id])
  adminId Int
  order   Order?  @relation(fields: [orderId], references: [id])
  orderId Int?
  amount  Float
  note    String?

  createdAt DateTime @default(now())

  @@index([adminId])
  @@map("profit_ledger")
}

enum OrderType {
  SELF
  CUSTOMER
  ADMIN
}

// NOTE: Removed duplicate CANCELED — only CANCELLED is used throughout the codebase.
enum OrderStatus {
  PENDING
  PROCESSING
  CONFIRMED
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
}

// =====================================================
// PAYMENTS
// =====================================================

model Payment {
  id            Int           @id @default(autoincrement())
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       Int           @unique
  user          User          @relation(fields: [userId], references: [id])
  userId        Int
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("payments")
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  UPI
  CASH
  NET_BANKING
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// =====================================================
// NOTIFICATIONS
// =====================================================

model Notification {
  id      Int              @id @default(autoincrement())
  userId  Int?
  type    NotificationType
  message String
  isRead  Boolean          @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

enum NotificationType {
  LOW_STOCK
  ORDER_UPDATE
  PAYMENT_STATUS
  SYSTEM_ALERT
}

model ProductNotification {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  email     String
  notified  Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([notified])
  @@map("product_notifications")
}
