// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------
// USERS TABLE
// ----------------------
model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  phone         String?  @unique

  // Optional profile fields
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  postalCode    String?
  country       String?
  photoUrl      String?

  monthlyLimit  Float?   // Optional monthly spending cap for SELF orders (in store currency)

  passwordHash  String
  role          Role     @default(CUSTOMER)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

enum Role {
  CUSTOMER
  ADMIN
}


model Product {
  id                Int       @id @default(autoincrement())
  uid               String    @unique @default(uuid()) // immutable unique identifier, used internally
  name              String
  description       String?
  keywords          String[]  @default([])
  category          Category
  subCategory       String
  costPrice         Float
  baseSellingPrice  Float
  bargainable       Boolean   @default(true)
  totalStock        Int       @default(0)
  totalSold         Int       @default(0)
  lowStockThreshold Int       @default(10)
  isActive          Boolean   @default(true)

  images            ProductImage[]
  inventoryLogs     InventoryLog[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("products")
  @@index([name])
  @@index([uid])
} 

model ProductImage {
  id        Int     @id @default(autoincrement())
  product   Product @relation(fields: [productId], references: [id])
  productId Int
  url       String
  altText   String?
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("product_images")
}

model InventoryLog {
  id        Int             @id @default(autoincrement())
  product   Product         @relation(fields: [productId], references: [id])
  productId Int
  action    InventoryAction
  quantity  Int
  admin     User?           @relation(fields: [adminId], references: [id])
  adminId   Int?
  note      String?
  createdAt DateTime        @default(now())

  @@map("inventory_logs")
}

enum InventoryAction {
  ADD
  RESTOCK
  SALE
  ADJUST
}

enum Category {
  STATIONERY
  BOOKS
  TOYS
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderType {
  SELF
  CUSTOMER
  ADMIN
}

model Order {
  id         Int       @id @default(autoincrement())
  uid        String    @unique @default(uuid())

  // Who placed the order (customer or admin)
  placedBy   User?     @relation(fields: [placedById], references: [id])
  placedById Int?

  // Admin responsible or owner for self-orders (optional)
  admin      User?     @relation("AdminOrders", fields: [adminId], references: [id])
  adminId    Int?

  type       OrderType @default(CUSTOMER)
  status     OrderStatus @default(PENDING)

  recipientName  String
  recipientPhone String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  country        String?
  note           String?

  totalSp    Float    @default(0)
  totalCp    Float    @default(0)

  items      OrderItem[]
  audits     OrderAudit[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("orders")
  @@index([createdAt])
}

model OrderAudit {
  id        Int         @id @default(autoincrement())
  order     Order       @relation(fields: [orderId], references: [id])
  orderId   Int
  admin     User?       @relation(fields: [adminId], references: [id])
  adminId   Int?
  fromStatus OrderStatus
  toStatus   OrderStatus
  note       String?
  createdAt  DateTime    @default(now())

  @@map("order_audits")
  @@index([orderId])
}

model ProfitLedger {
  id       Int      @id @default(autoincrement())
  admin    User     @relation(fields: [adminId], references: [id])
  adminId  Int
  order    Order?   @relation(fields: [orderId], references: [id])
  orderId  Int?
  amount   Float
  note     String?
  createdAt DateTime @default(now())

  @@map("profit_ledger")
  @@index([adminId])
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  order       Order   @relation(fields: [orderId], references: [id])
  orderId     Int

  product     Product? @relation(fields: [productId], references: [id])
  productId   Int?

  productName String
  productPhoto String?

  quantity    Int
  cp          Float
  sp          Float
  subtotalSp  Float
  subtotalCp  Float

  createdAt   DateTime @default(now())

  @@map("order_items")
}
